{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:osod:v0.1:schema:osod-logbook-record",
  "title": "OSOD Logbook Record",
  "description": "OSOD v0.1 operationeel brandweerduiklogboekrecord. Publieke conceptversie.",
  "type": "object",
  "required": [
    "osodVersion",
    "recordId",
    "recordType",
    "conformanceClaims",
    "createdAt",
    "context",
    "roles",
    "dive",
    "signoff"
  ],
  "additionalProperties": false,
  "properties": {
    "osodVersion": {
      "const": "0.1"
    },
    "recordId": {
      "type": "string",
      "format": "uuid"
    },
    "recordType": {
      "const": "operationeleDuikregistratie"
    },
    "conformanceClaims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "S",
          "R"
        ]
      },
      "contains": {
        "const": "S"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceSystem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "exportedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "context": {
      "$ref": "#/$defs/context"
    },
    "roles": {
      "$ref": "#/$defs/roles"
    },
    "dive": {
      "$ref": "#/$defs/dive"
    },
    "signoff": {
      "$ref": "#/$defs/signoff"
    },
    "calculation": {
      "anyOf": [
        {
          "$ref": "#/$defs/calculation"
        },
        {
          "type": "null"
        }
      ]
    },
    "incidentReference": {
      "anyOf": [
        {
          "$ref": "#/$defs/incidentReference"
        },
        {
          "type": "null"
        }
      ]
    },
    "extensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "conformanceClaims": {
            "contains": {
              "const": "R"
            }
          }
        },
        "required": [
          "conformanceClaims"
        ]
      },
      "then": {
        "required": [
          "calculation"
        ],
        "properties": {
          "calculation": {
            "$ref": "#/$defs/calculation"
          }
        }
      }
    }
  ],
  "$defs": {
    "context": {
      "type": "object",
      "required": [
        "veiligheidsregio",
        "locatie",
        "activiteitType"
      ],
      "additionalProperties": false,
      "properties": {
        "veiligheidsregio": {
          "type": "string",
          "minLength": 1
        },
        "duikteam": {
          "type": "string"
        },
        "locatie": {
          "type": "object",
          "required": [
            "omschrijving"
          ],
          "additionalProperties": false,
          "properties": {
            "omschrijving": {
              "type": "string",
              "minLength": 1
            },
            "waterType": {
              "type": "string"
            },
            "coordinates": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "lat": {
                  "type": "number",
                  "minimum": -90,
                  "maximum": 90
                },
                "lon": {
                  "type": "number",
                  "minimum": -180,
                  "maximum": 180
                }
              },
              "required": [
                "lat",
                "lon"
              ]
            }
          }
        },
        "activiteitType": {
          "enum": [
            "oefening",
            "inzet",
            "training",
            "reintegratie",
            "anders"
          ]
        },
        "oefencode": {
          "type": [
            "string",
            "null"
          ]
        },
        "omschrijving": {
          "type": "string"
        }
      }
    },
    "personRef": {
      "type": "object",
      "required": [
        "displayName",
        "role"
      ],
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "localPersonId": {
          "type": "string"
        },
        "registrationNumber": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "isReserveduiker": {
          "type": "boolean"
        },
        "isSignaalhouder": {
          "type": "boolean"
        }
      }
    },
    "roles": {
      "type": "object",
      "required": [
        "duikploegleider",
        "duikers"
      ],
      "additionalProperties": false,
      "properties": {
        "duikploegleider": {
          "$ref": "#/$defs/personRef"
        },
        "duikers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/personRef"
          }
        },
        "duikmedischBegeleider": {
          "$ref": "#/$defs/personRef"
        }
      }
    },
    "dive": {
      "type": "object",
      "required": [
        "datum",
        "tijdIn",
        "duiktijdMin",
        "maximaleDiepteWerkelijkM",
        "gevolgdSchema",
        "decompressieverloop",
        "ademgas",
        "duiksysteem",
        "aardDuikarbeid",
        "aantalDuikers",
        "bijzondereSessies"
      ],
      "additionalProperties": false,
      "properties": {
        "datum": {
          "type": "string",
          "format": "date"
        },
        "tijdIn": {
          "type": "string",
          "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$"
        },
        "tijdUit": {
          "type": "string",
          "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9](:[0-5][0-9])?$"
        },
        "duiktijdMin": {
          "type": "integer",
          "minimum": 0
        },
        "totaleTijdOnderDrukMin": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "maximaleDiepteWerkelijkM": {
          "type": "number",
          "minimum": 0
        },
        "tabelDiepteM": {
          "type": [
            "integer",
            "null"
          ],
          "enum": [
            6,
            9,
            12,
            15,
            null
          ]
        },
        "gevolgdSchema": {
          "type": "object",
          "required": [
            "schemaType",
            "naam"
          ],
          "additionalProperties": false,
          "properties": {
            "schemaType": {
              "enum": [
                "DCIEM_AIR_TABLE",
                "METERREGEL",
                "LOKAAL",
                "NIET_BEREKEND",
                "ANDERS"
              ]
            },
            "naam": {
              "type": "string"
            },
            "bronId": {
              "type": "string"
            },
            "versie": {
              "type": "string"
            }
          }
        },
        "decompressieverloop": {
          "type": "object",
          "required": [
            "type"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "enum": [
                "NO_DECO",
                "DECO",
                "AFGEBROKEN",
                "ONBEKEND",
                "ANDERS"
              ]
            },
            "stops": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "diepteM",
                  "duurMin"
                ],
                "additionalProperties": false,
                "properties": {
                  "diepteM": {
                    "type": "number",
                    "minimum": 0
                  },
                  "duurMin": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              }
            },
            "omschrijving": {
              "type": "string"
            }
          }
        },
        "ademgas": {
          "enum": [
            "ademlucht",
            "zuurstof",
            "nitrox",
            "heliox",
            "anders",
            "onbekend"
          ]
        },
        "duiksysteem": {
          "enum": [
            "SCUBA",
            "SCUBA_OLV",
            "SSE",
            "anders",
            "onbekend"
          ]
        },
        "aardDuikarbeid": {
          "enum": [
            "oefening",
            "inzet",
            "redding",
            "berging",
            "training",
            "reintegratie",
            "anders"
          ]
        },
        "aantalDuikers": {
          "type": "integer",
          "minimum": 1
        },
        "bijzondereSessies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "signoff": {
      "type": "object",
      "required": [
        "status",
        "duikploegleiderGetekend",
        "werkgeverOfOpdrachtgeverGetekend"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "concept",
            "vastgelegd",
            "gecorrigeerd",
            "ongeldig"
          ]
        },
        "duikploegleiderGetekend": {
          "type": "boolean"
        },
        "werkgeverOfOpdrachtgeverGetekend": {
          "type": "boolean"
        },
        "toelichting": {
          "type": "string"
        }
      }
    },
    "calculation": {
      "type": "object",
      "required": [
        "status",
        "resultValid",
        "engine",
        "inputEnvelope",
        "blockingReasons",
        "messages"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "NOT_CALCULATED",
            "GREEN",
            "AMBER",
            "RED",
            "BLOCKED"
          ]
        },
        "resultValid": {
          "type": "boolean"
        },
        "engine": {
          "type": "object",
          "required": [
            "name",
            "version",
            "tableSourceId"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "tableSourceId": {
              "type": "string"
            },
            "tableFingerprintSha256": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            }
          }
        },
        "inputEnvelope": {
          "type": "object",
          "additionalProperties": true
        },
        "outputs": {
          "type": "object",
          "additionalProperties": true
        },
        "blockingReasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "RED",
                  "BLOCKED"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "resultValid": {
                "const": false
              },
              "blockingReasons": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "resultValid": {
                "const": true
              }
            },
            "required": [
              "resultValid"
            ]
          },
          "then": {
            "properties": {
              "blockingReasons": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "GREEN"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "blockingReasons": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "incidentReference": {
      "type": "object",
      "required": [
        "hasIncidentRecord"
      ],
      "additionalProperties": false,
      "properties": {
        "hasIncidentRecord": {
          "type": "boolean"
        },
        "referenceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
